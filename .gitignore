############################################
# Terraform Files
############################################

# Terraform working directory
.terraform/

# Terraform state files (NEVER COMMIT)
*.tfstate
*.tfstate.*
terraform.tfstate
terraform.tfstate.backup

# Crash logs
crash.log
crash.*.log

# Override files (local variables)
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI config
.terraformrc
terraform.rc


############################################
# Terraform Lock File (OPTIONAL - KEEP IT)
############################################
# IMPORTANT:
# You SHOULD commit this file for consistency
# .terraform.lock.hcl


############################################
# AWS Credentials (NEVER COMMIT)
############################################

.aws/
aws-credentials
credentials
*.pem
*.key


############################################
# System Files (Windows / Mac / Linux)
############################################

# Windows
Thumbs.db
Desktop.ini

# Mac
.DS_Store

# Linux
*.swp
*.swo


############################################
# IDE / Editor Files
############################################

.vscode/
.idea/
*.iml

# Logs from editors
npm-debug.log*
yarn-debug.log*
yarn-error.log*


############################################
# Environment Variables
############################################

.env
.env.*
*.env


############################################
# Node (if used in future projects)
############################################

node_modules/


############################################
# Misc
############################################

*.log
*.bak
*.tmp